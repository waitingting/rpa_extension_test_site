{
  "name": "rpa-extension-test-site",
  "version": "1.0.0",
  "private": true,
  "description": "Local fixture site for browser extension capture and automation tests.",
  "scripts": {
    "start": "pwsh -NoProfile -File scripts/start.ps1",
    "start:main": "http-server sites/extension-fixtures/main -a 127.0.0.1 -p 8007 -c-1 --cors",
    "start:cross-a": "http-server sites/extension-fixtures/cross-a -a 127.0.0.1 -p 8008 -c-1 --cors",
    "start:cross-b": "http-server sites/extension-fixtures/cross-b -a 127.0.0.1 -p 8009 -c-1 --cors",
    "test:browser": "playwright test --headed",
    "test:browser:smoke": "playwright test browser-smoke.spec.js --headed",
    "test:fixture": "playwright test fixture-site.spec.js --headed",
    "test:extension": "playwright test rpad-extension-smoke.spec.js --headed"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "http-server": "^14.1.1"
  }
}
